#!/bin/bash

PATH="/usr/local/bin:/opt/homebrew/bin:/usr/sbin:/sbin:/usr/bin:/bin"

# colors
reset=$'\033[0m'
bold=$'\033[1m'

white=$'\033[38;2;255;255;255m'
pink=$'\033[38;2;255;105;235m'
purple=$'\033[38;2;170;110;255m'
cyan=$'\033[38;2;90;255;220m'
dim=$'\033[38;2;120;120;120m'

selected=0

main_menu_items=(
  "1. View Inactive Ports"
  "2. Run Speed Test"
  "3. Tools"
  "4. Quit"
)

tools_menu_items=(
  "1. Flush DNS"
  "2. Renew DHCP"
  "3. Show Public IP"
  "4. Ping Default Gateway"
  "5. Reset Network Settings"
  "6. Back"
)

# active interface data
active_name=""
active_dev=""
active_ip=""
active_ipv6=""
active_mac=""
active_mask=""
active_router=""
active_dns=""
active_dhcp_enabled=""
active_dhcp_server=""

cleanup() {
  tput sgr0
  tput cnorm
  tput rmcup
  stty sane 2>/dev/null
}

init_ui() {
  tput smcup
  tput civis
  stty -echo -icanon min 1 time 0 2>/dev/null
  trap cleanup EXIT INT TERM
}

draw_header() {
  clear
  printf "%s" "$pink"
  cat <<'EOF'
 _   _      _   _____        __       
| \ | | ___| |_|_   _|_ __  / _| ___  
|  \| |/ _ \ __| | | | '_ \| |_ / _ \ 
| |\  |  __/ |_  | | | | | |  _| (_) |
|_| \_|\___|\__| |_| |_| |_|_|  \___/ 
EOF
  printf "%s" "$reset"
  echo "${pink}Simple Network Information for MacOS${reset}"
}

# trims long values so they dont wrap
trim_value() {
  local value="$1"
  local cols
  local max

  cols=$(tput cols)
  max=$((cols - 33))
  [ "$max" -lt 10 ] && max=10

  if [ "${#value}" -gt "$max" ]; then
    printf "%s..." "${value:0:$((max - 3))}"
  else
    printf "%s" "$value"
  fi
}

# formats aligned output
format_line() {
  local label="$1"
  local value="$2"
  local trimmed

  trimmed=$(trim_value "$value")
  printf "%-28s : %s\n" "$label" "$trimmed"
}

# finds the active network interface
load_active_interface() {
  active_name=""
  active_dev=""
  active_ip=""
  active_ipv6=""
  active_mac=""
  active_mask=""
  active_router=""
  active_dns=""
  active_dhcp_enabled=""
  active_dhcp_server=""

  while IFS="|" read -r port dev; do
    [ -z "$dev" ] && continue

    ip=$(/usr/sbin/ipconfig getifaddr "$dev" 2>/dev/null)
    if [ -n "$ip" ]; then
      active_name="$port"
      active_dev="$dev"
      active_ip="$ip"

      # get ipv6 and ignore link-local
      active_ipv6=$(ifconfig "$dev" 2>/dev/null | awk '/inet6 / && $2 !~ /^fe80:/ {print $2; exit}')

      # get mac address
      active_mac=$(ifconfig "$dev" 2>/dev/null | awk '/ether / {print $2; exit}')

      # get subnet mask and gateway
      active_mask=$(/usr/sbin/ipconfig getoption "$dev" subnet_mask 2>/dev/null)
      active_router=$(/usr/sbin/ipconfig getoption "$dev" router 2>/dev/null)

      # get dns servers
      dns_raw=$(/usr/sbin/networksetup -getdnsservers "$port" 2>/dev/null)
      if echo "$dns_raw" | grep -q "^There"; then
        active_dns="(none explicitly set)"
      else
        active_dns=$(echo "$dns_raw" | paste -sd " " -)
      fi

      # get dhcp info
      dhcp_packet=$(/usr/sbin/ipconfig getpacket "$dev" 2>/dev/null)
      if [ -n "$dhcp_packet" ]; then
        active_dhcp_enabled="Yes"
        active_dhcp_server=$(echo "$dhcp_packet" | awk '/server_identifier/ {print $3; exit}')
      else
        active_dhcp_enabled="No"
        active_dhcp_server="N/A"
      fi

      return
    fi
  done < <(
    /usr/sbin/networksetup -listallhardwareports | awk '
      /Hardware Port:/ {
        port = $0
        sub("Hardware Port: ", "", port)
      }
      /Device:/ {
        dev = $2
        print port "|" dev
      }
    '
  )
}

draw_active_interface() {
  load_active_interface

  if [ -n "$active_dev" ]; then
    echo
    echo "${cyan}${bold}Default Interface : ${active_name} (${active_dev})${reset}"
    echo

    format_line "IPv4 Address" "${active_ip:-N/A}"
    format_line "Subnet Mask" "${active_mask:-N/A}"
    format_line "Default Gateway" "${active_router:-N/A}"
    format_line "DNS Servers" "${active_dns:-N/A}"
    format_line "MAC Address" "${active_mac:-N/A}"
    format_line "IPv6 Address" "${active_ipv6:-N/A}"
    format_line "DHCP Enabled" "${active_dhcp_enabled:-N/A}"
    format_line "DHCP Server" "${active_dhcp_server:-N/A}"
    echo
  else
    echo
    echo "${white}No active interfaces detected${reset}"
    echo
  fi
}

# shows inactive interfaces
draw_inactive_ports() {
  clear
  draw_header
  echo

  found=0
  while IFS="|" read -r port dev; do
    [ -z "$dev" ] && continue

    ip=$(/usr/sbin/ipconfig getifaddr "$dev" 2>/dev/null)
    if [ -z "$ip" ]; then
      found=1
      echo "${white}${port} (${dev})${reset}"
      format_line "IP Address" "None"
      format_line "Subnet Mask" "N/A"
      format_line "Gateway" "N/A"
      format_line "DNS Servers" "N/A"
      echo
    fi
  done < <(
    /usr/sbin/networksetup -listallhardwareports | awk '
      /Hardware Port:/ {
        port = $0
        sub("Hardware Port: ", "", port)
      }
      /Device:/ {
        dev = $2
        print port "|" dev
      }
    '
  )

  if [ "$found" -eq 0 ]; then
    echo "${white}No inactive ports found${reset}"
  fi

  echo
  echo "${dim}Press any key to go back${reset}"
  read -rsn1
}

draw_menu() {
  local row=19
  local mode="$1"
  local items_ref=()
  local i

  if [ "$mode" = "main" ]; then
    items_ref=("${main_menu_items[@]}")
  else
    items_ref=("${tools_menu_items[@]}")
  fi

  for i in "${!items_ref[@]}"; do
    tput cup $((row + i)) 0
    tput el
    if [ "$i" -eq "$selected" ]; then
      printf "%b" "${pink}> ${items_ref[$i]}${reset}"
    else
      printf "%b" "${white}  ${items_ref[$i]}${reset}"
    fi
  done

  tput cup $((row + ${#items_ref[@]} + 1)) 0
  tput el
  printf "%b" "${dim}‚ÜĎ ‚Üď arrows or press a number and Enter${reset}"
}

update_menu_selection() {
  local row=19
  local mode="$1"
  local old_selected="$2"
  local new_selected="$3"
  local items_ref=()

  if [ "$mode" = "main" ]; then
    items_ref=("${main_menu_items[@]}")
  else
    items_ref=("${tools_menu_items[@]}")
  fi

  tput cup $((row + old_selected)) 0
  tput el
  printf "%b" "${white}  ${items_ref[$old_selected]}${reset}"

  tput cup $((row + new_selected)) 0
  tput el
  printf "%b" "${pink}> ${items_ref[$new_selected]}${reset}"
}

# runs speed test
run_speedtest() {
  clear
  draw_header
  echo

  if ping -c 2 1.1.1.1 >/dev/null 2>&1; then
    ping_ms=$(ping -c 4 1.1.1.1 2>/dev/null | awk -F'/' 'END { print $5 " ms" }')

    tmpfile=$(mktemp)
    networkQuality > "$tmpfile" 2>/dev/null &
    pid=$!

    frames=("‚Ėį‚ĖĪ‚ĖĪ‚ĖĪ‚ĖĪ‚ĖĪ" "‚Ėį‚Ėį‚ĖĪ‚ĖĪ‚ĖĪ‚ĖĪ" "‚Ėį‚Ėį‚Ėį‚ĖĪ‚ĖĪ‚ĖĪ" "‚Ėį‚Ėį‚Ėį‚Ėį‚ĖĪ‚ĖĪ" "‚Ėį‚Ėį‚Ėį‚Ėį‚Ėį‚ĖĪ" "‚Ėį‚Ėį‚Ėį‚Ėį‚Ėį‚Ėį")
    i=0

    while kill -0 "$pid" 2>/dev/null; do
      printf "\r${pink}%s${reset} ${white}Running speed test...${reset}" "${frames[$i]}"
      i=$(( (i + 1) % ${#frames[@]} ))
      sleep 0.15
    done

    wait "$pid"
    echo
    echo

    nq=$(cat "$tmpfile")
    rm -f "$tmpfile"

    dl=$(echo "$nq" | awk -F': ' '
      /Downlink capacity|Download capacity|Downlink throughput|Download throughput/ {
        print $2
        exit
      }')

    ul=$(echo "$nq" | awk -F': ' '
      /Uplink capacity|Upload capacity|Uplink throughput|Upload throughput/ {
        print $2
        exit
      }')

    echo "${white}Ping            : ${ping_ms:-N/A}${reset}"
    echo "${white}Download Speed  : ${dl:-N/A}${reset}"
    echo "${white}Upload Speed    : ${ul:-N/A}${reset}"
  else
    echo "${white}Can't run speed test without internet ya dummy!${reset}"
  fi

  echo
  echo "${dim}Press any key to go back${reset}"
  read -rsn1
}

# flushes dns cache
tool_flush_dns() {
  clear
  draw_header
  echo
  echo "${purple}${bold}Flush DNS${reset}"
  echo

  sudo dscacheutil -flushcache
  sudo killall -HUP mDNSResponder

  if [ $? -eq 0 ]; then
    echo "${white}DNS cache flushed successfully.${reset}"
  else
    echo "${white}Could not flush DNS cache.${reset}"
  fi

  echo
  echo "${dim}Press any key to go back${reset}"
  read -rsn1
}

# renews dhcp lease
tool_renew_dhcp() {
  clear
  draw_header
  echo
  echo "${purple}${bold}Renew DHCP${reset}"
  echo

  load_active_interface

  if [ -z "$active_dev" ]; then
    echo "${white}No active interface found.${reset}"
  else
    echo "${white}Renewing DHCP on ${active_name} (${active_dev})...${reset}"
    echo
    sudo ipconfig set "$active_dev" DHCP

    if [ $? -eq 0 ]; then
      echo "${white}DHCP lease renewed successfully.${reset}"
    else
      echo "${white}Could not renew DHCP lease.${reset}"
    fi
  fi

  echo
  echo "${dim}Press any key to go back${reset}"
  read -rsn1
}

# gets public ip
tool_show_public_ip() {
  clear
  draw_header
  echo
  echo "${purple}${bold}Show Public IP${reset}"
  echo

  public_ip=$(curl -s --max-time 5 ifconfig.me 2>/dev/null)
  [ -z "$public_ip" ] && public_ip=$(curl -s --max-time 5 icanhazip.com 2>/dev/null)

  if [ -n "$public_ip" ]; then
    echo "${white}Public IP Address : ${public_ip}${reset}"
  else
    echo "${white}Could not determine public IP.${reset}"
  fi

  echo
  echo "${dim}Press any key to go back${reset}"
  read -rsn1
}

# pings default gateway
tool_ping_gateway() {
  clear
  draw_header
  echo
  echo "${purple}${bold}Ping Default Gateway${reset}"
  echo

  load_active_interface

  if [ -z "$active_router" ]; then
    echo "${white}No default gateway found.${reset}"
    echo
    echo "${dim}Press any key to go back${reset}"
    read -rsn1
    return
  fi

  echo "${white}Pinging ${active_router}...${reset}"
  echo
  ping -c 4 "$active_router"

  echo
  echo "${dim}Press any key to go back${reset}"
  read -rsn1
}

# resets basic network state
tool_reset_network() {
  clear
  draw_header
  echo
  echo "${purple}${bold}Reset Network Settings${reset}"
  echo
  echo "${white}Are you sure?${reset}"
  echo
  echo "${white}This will:${reset}"
  echo "${white}- Flush DNS cache${reset}"
  echo "${white}- Renew DHCP on the active interface${reset}"
  echo "${white}- Briefly restart that interface${reset}"
  echo
  echo "${white}Your network connection may drop for a few seconds.${reset}"
  echo
  echo "${pink}Press Y to continue or any other key to cancel.${reset}"

  read -rsn1 confirm

  if [[ "$confirm" != "Y" && "$confirm" != "y" ]]; then
    return
  fi

  clear
  draw_header
  echo
  echo "${purple}${bold}Reset Network Settings${reset}"
  echo

  load_active_interface

  if [ -z "$active_dev" ]; then
    echo "${white}No active interface found.${reset}"
    echo
    echo "${dim}Press any key to go back${reset}"
    read -rsn1
    return
  fi

  echo "${white}Flushing DNS cache...${reset}"
  sudo dscacheutil -flushcache
  sudo killall -HUP mDNSResponder

  echo "${white}Renewing DHCP on ${active_name} (${active_dev})...${reset}"
  sudo ipconfig set "$active_dev" DHCP

  echo "${white}Restarting ${active_name} (${active_dev})...${reset}"
  sudo ifconfig "$active_dev" down
  sleep 2
  sudo ifconfig "$active_dev" up

  echo
  echo "${white}Basic network reset complete.${reset}"
  echo
  echo "${dim}Press any key to go back${reset}"
  read -rsn1
}

# maps cmd string to actino 
run_pipe_command() {
  local cmd="$1"
  draw_header
  echo
  case "$cmd" in
    inactive|"inactive ports"|1)   draw_inactive_ports ;;
    speedtest|speed|2)             run_speedtest ;;
    "flush dns"|flushdns)          tool_flush_dns ;;
    "renew dhcp"|renewdhcp)        tool_renew_dhcp ;;
    "public ip"|publicip|ip)       tool_show_public_ip ;;
    "ping gateway"|pinggateway)    tool_ping_gateway ;;
    "reset network"|resetnetwork)  tool_reset_network ;;
    info|status|"")
      load_active_interface
      draw_active_interface
      ;;
    *)
      echo "${white}Unknown command: ${cmd}${reset}"
      echo
      echo "${white}Available commands:${reset}"
      echo "  info             - show active interface info (default)"
      echo "  inactive         - view inactive ports"
      echo "  speedtest        - run speed test"
      echo "  flush dns        - flush DNS cache"
      echo "  renew dhcp       - renew DHCP lease"
      echo "  public ip        - show public IP"
      echo "  ping gateway     - ping default gateway"
      echo "  reset network    - reset network settings"
      echo
      exit 1
      ;;
  esac
}

read_key() {
  IFS= read -rsn1 key

  case "$key" in
    $'\x1b')
      IFS= read -rsn2 rest
      case "$rest" in
        "[A") echo up ;;
        "[B") echo down ;;
      esac
      ;;
    $'\n'|$'\r'|'')
      echo enter
      ;;
    [1-6])
      echo "$key"
      ;;
  esac
}

redraw_home() {
  draw_header
  draw_active_interface
  draw_menu main
}

tools_loop() {
  selected=0
  draw_header
  draw_active_interface
  draw_menu tools

  while true; do
    action=$(read_key)

    case "$action" in
      up)
        old_selected=$selected
        selected=$((selected - 1))
        [ $selected -lt 0 ] && selected=$((${#tools_menu_items[@]} - 1))
        update_menu_selection tools "$old_selected" "$selected"
        ;;
      down)
        old_selected=$selected
        selected=$((selected + 1))
        [ $selected -ge ${#tools_menu_items[@]} ] && selected=0
        update_menu_selection tools "$old_selected" "$selected"
        ;;
      enter)
        case "$selected" in
          0) tool_flush_dns ;;
          1) tool_renew_dhcp ;;
          2) tool_show_public_ip ;;
          3) tool_ping_gateway ;;
          4) tool_reset_network ;;
          5) return ;;
        esac
        draw_header
        draw_active_interface
        draw_menu tools
        ;;
      1)
        tool_flush_dns
        draw_header
        draw_active_interface
        draw_menu tools
        ;;
      2)
        tool_renew_dhcp
        draw_header
        draw_active_interface
        draw_menu tools
        ;;
      3)
        tool_show_public_ip
        draw_header
        draw_active_interface
        draw_menu tools
        ;;
      4)
        tool_ping_gateway
        draw_header
        draw_active_interface
        draw_menu tools
        ;;
      5)
        tool_reset_network
        draw_header
        draw_active_interface
        draw_menu tools
        ;;
      6)
        return
        ;;
    esac
  done
}

main_loop() {
  redraw_home

  while true; do
    action=$(read_key)

    case "$action" in
      up)
        old_selected=$selected
        selected=$((selected - 1))
        [ $selected -lt 0 ] && selected=$((${#main_menu_items[@]} - 1))
        update_menu_selection main "$old_selected" "$selected"
        ;;
      down)
        old_selected=$selected
        selected=$((selected + 1))
        [ $selected -ge ${#main_menu_items[@]} ] && selected=0
        update_menu_selection main "$old_selected" "$selected"
        ;;
      enter)
        case "$selected" in
          0)
            draw_inactive_ports
            redraw_home
            ;;
          1)
            run_speedtest
            redraw_home
            ;;
          2)
            tools_loop
            redraw_home
            ;;
          3)
            break
            ;;
        esac
        ;;
      1)
        draw_inactive_ports
        redraw_home
        ;;
      2)
        run_speedtest
        redraw_home
        ;;
      3)
        tools_loop
        redraw_home
        ;;
      4)
        break
        ;;
    esac
  done
}

if [ ! -t 0 ]; then
  IFS= read -r piped_cmd
  run_pipe_command "$piped_cmd"
  exit 0
fi

init_ui
main_loop
